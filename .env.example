# Variáveis de ambiente — copie este arquivo para .env.local e preencha os valores

# URL do projeto Supabase (encontrada em: Supabase Dashboard → Settings → API → Project URL)
SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co

# Chave service_role — NUNCA exponha no frontend ou comite no git
# Encontrada em: Supabase Dashboard → Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# Chave anon — usada pelo cliente do frontend (Next.js)
# Encontrada em: Supabase Dashboard → Settings → API → anon (public)
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# ─── E-mail (SMTP) — envio da senha provisória no fluxo de acesso (v4.24.0) ───
# OPCIONAL. Sem estas variáveis, a senha provisória continua exibida na tela (fallback);
# preenchê-las no .env.local (e no ambiente da Vercel) habilita o envio automático.
# Office 365: SMTP_HOST=smtp.office365.com · SMTP_PORT=587 · SMTP_SECURE=false (STARTTLS).
# SMTP_FROM (remetente) normalmente deve ser IGUAL ao SMTP_USER no Office 365.
# NUNCA comite valores reais aqui — só no .env.local (gitignored) / Vercel.
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
